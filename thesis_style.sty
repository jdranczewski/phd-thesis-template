%\ProvidesPackage{jbd17style}

%%%% Load packages %%%%

% For comprehensive documentation on any of the packages listed here,
% look it up on https://ctan.org/ and select "User manual".

% Enable utf8 encoding and T1 font encoding to support more special characters
% (especially in different languages)
\usepackage[utf8x]{inputenc}
\usepackage[T1]{fontenc}
\usepackage{ucs}
\usepackage{textcomp} % Additional symbols
% Use Latin Modern fonts to display the T1 font nicely
\usepackage{lmodern}

% Enable a bunch of typographical refinement, see https://www.khirevich.com/latex/microtype/
\usepackage{microtype}

% More mathematical typesetting features
\usepackage{amsmath}
\usepackage{amsfonts}
\usepackage{bm} % Bold symbols in maths mode
\usepackage{amssymb}

% Figure enhancements
\usepackage{graphicx}
\graphicspath{{figures/}} % Search for figures in the 'figures' folder
\usepackage[export]{adjustbox} % Additional options for \includegraphics
\usepackage{wrapfig} % Figures that text can wrap around

% Generate lorem ipsum text
\usepackage{lipsum}

% Indent the first line of each paragraph
\usepackage{indentfirst}

% Double horizontal lines in tables situations
\usepackage{hhline}

% Add the bibliography, table of contents, etc to the table of contents
\usepackage{tocbibind}

% Typeset source code. See sections/appendices.tex for an example
\usepackage{listings}

% More control over the layout of enumerate and itemize
\usepackage{enumitem}

%%%% Useful tools %%%%

%% Set up acronyms
\usepackage{acronym}
% Emphasise the acronym in the acronym list, see sections/acronym_list.tex for usage details
\renewcommand*\acffont{\emph}
\renewcommand*\acfsfont{\emph}

%% Display chemical formulas with correct formatting,
% example: \ch{Al2(SO4)3}
\usepackage{chemformula}

%% SI unit display, see "sections/example.tex" for usage.
\usepackage{siunitx}
\sisetup{separate-uncertainty}
% better tilde character for uncertainty indication
\newcommand{\goodtilde}{{\raise.17ex\hbox{$\scriptstyle\mathtt{\sim}$}}}
% You can define custom SI units here, for use in \qty calls.
\DeclareSIUnit\pulse{\text{pulse}}
\DeclareSIUnit\perpulse{\text{/pulse}}
\DeclareSIUnit\fluence{\micro\joule\per\centi\meter\squared\per\pulse}

%%%% Useful environments %%%%

%% Outline environment
% Makes an itemize that's blue, for writing out section outlines
\newenvironment{outline}{\begin{itemize}\color{blue}}{\end{itemize}}
% Also define outlineDone, which doesn't render the environment contents to the final document. Useful for keeping the outlines in the source, but not in the thesis.
\usepackage{scontents}
\newenvsc{outlineDone}[store-env=forshort,print-env=false]
% See sections/example.tex for example usage

%% Originality statement environment for the beginning of a chapter, see sections/example.tex
\newenvironment{originality}{\vspace{-2.7em}\small}{
	\par
	\color{dark}
	\noindent\rule{\textwidth}{0.5pt}
	\vspace{-.7em}
}

%%%% Style settings %%%%

% Set line spread. Note that this is not the same as the line spacing in Word.
% See https://tex.stackexchange.com/questions/65849/confusion-onehalfspacing-vs-spacing-vs-word-vs-the-world
% I think 1.5 looks good, and it's equivalent to maybe 1.75 in Word units?
\usepackage{setspace}
\linespread{1.5}

\renewcommand{\thefootnote}{\fnsymbol{footnote}}

%% Set up colours
% I mostly use a blue colour scheme, adapted from the old Imperial logo's blue. Feel free to change it!
\usepackage[]{xcolor}
\definecolor{blue}{RGB}{13,71,161}
\definecolor{dark}{RGB}{0,60,112}
\definecolor{darker}{RGB}{0,40,74}
\definecolor{blackish}{RGB}{50,50,50}
\colorlet{defaultcolor}{.}
% Also tested 0 30 55, which was a bit too bright

%% Style section titles to use the colours defined above
\usepackage{sectsty}
\sectionfont{\color{darker}}
\subsectionfont{\color{darker}}
\subsubsectionfont{\color{darker}}

%% Set up hyperlinks
% hidelinks doesn't show the coloured boxes around all links, instead we change the link colour below
\usepackage[hidelinks, pdfa]{hyperref}
% Change link colours
\makeatletter % This command lets us use LaTeX commands that contain "@"s, which is normally disabled as a protection
\hypersetup{
	colorlinks=true,
	linkcolor=dark,
	citecolor=dark,
	urlcolor=dark,
	pdftitle=\@title
}
\makeatother

%% Set up caption styles
% to have nice margins and a slightly different font colour
\usepackage[margin={0cm,0.4cm}, oneside, indention=.4cm, labelfont={sc,color=darker}, textfont={small,color=blackish}]{caption}

%% Set up citations
% The default citation should be in the superscript
\usepackage[superscript, nomove]{cite}
% I would also like the superscript citations to include square brackets
\makeatletter
\renewcommand{\@citess}[1]{\textsuperscript{[#1]}}
\makeatother
% Add \citein as a command to quickly get a square-bracketed inline citation
\newcommand{\citein}[1]{[\citen{#1}]}

%% Make Table numbers sequential with Figure numbers
% You may want to change this if you have many tables, I only had one so it felt silly to count it separately
\makeatletter
\let\c@table\c@figure
\let\ftype@table\ftype@figure
\makeatother

%% Set up geometry
% including even margins all around
\usepackage[left=2.5cm, right=2.5cm, top=2.5cm, bottom=2.5cm, includehead, nomarginpar]{geometry}

%% Adjust spacing in the list of figures to account for double-digit figure numbers
% https://tex.stackexchange.com/a/87027
% https://latexref.xyz/_005c_0040dottedtocline.html
\makeatletter
\renewcommand*\l@figure{\@dottedtocline{1}{1em}{2.9em}}
\makeatother

%% Set up headers and footers
\usepackage{fancyhdr}

% Set the default page style to "fancy", and then modify said style below
\pagestyle{fancy}
% Clear the default footer
\fancyfoot{}
% Add a centred page number with some nice lines
\cfoot{\color{dark}\rule[3.5pt]{1em}{0.5pt}~~\color{darker}\thepage~~\color{dark}\rule[3.5pt]{1em}{0.5pt}}
% Clear the default header
\fancyhead{}
% Add the chapter and section names to the headers
% Adjust here if you want to add your name or something like that
\fancyhead[OR]{\color{darker}\rightmark}
\fancyhead[EL]{\color{darker}\leftmark}
% Adjust some parameters for the horizontal header line
\renewcommand{\headrulewidth}{0.5pt}
\renewcommand\headrule{%
	\nointerlineskip
	\smash{\color{dark}\rule{\headwidth}{\headrulewidth}}%
}

% Define a page style without a header
% Use this with \thispagestyle{plainheadline}
\fancypagestyle{plainheadline}{%
	\fancyhf{}%
	\renewcommand{\headrulewidth}{0pt}
	\fancyfoot[C]{\color{dark}\rule[3.5pt]{1em}{0.5pt}~~\color{darker}\thepage~~\color{dark}\rule[3.5pt]{1em}{0.5pt}}
}

%% Chapter title format
% You can include a pdf in `figures/_headers/` with a name matching the chapter number/letter (eg. 1.pdf or A.pdf) to use it as a small header image. `default.pdf` gets used by default if present.
\usepackage{titlesec}
\titleformat
{\chapter} % command to modify
[display] % shape
{\centering\LARGE\color{darker}\bfseries\linespread{1}} % format of the heading
{
	\vspace{-6.05em}
	\rule{\textwidth}{0.pt}
	\IfFileExists{figures/_headers/\thechapter.pdf}%test for header image
	{% true
		\vspace{-0.6em}
		\includegraphics[width=1.5in]{_headers/\thechapter.pdf}\\
	}
	{% false
		\IfFileExists{figures/_headers/default.pdf}
		{
			\vspace{-0.6em}
			\includegraphics[width=1.5in]{_headers/default.pdf}\\
		}
		{}
	}
	\chaptername~\thechapter
} % chapter label
{0.5ex} % sep
{
	\Huge
} % before label
[
	\vspace{-0.2em}
	\color{dark}
	\rule{\textwidth}{0.5pt}
] % after label

%% Epigraph styling, for the quote in the Acknowledgments
\usepackage{epigraph}
% Change the width of the epigrah here
\setlength{\epigraphwidth}{0.8\textwidth}
\renewcommand{\textflush}{flushepinormal}
\setlength{\beforeepigraphskip}{-\baselineskip}
\setlength{\afterepigraphskip}{2\baselineskip}
\setlength{\epigraphrule}{0.5pt}
% Modify the horizontal epigraph line to match the header one
\makeatletter
\renewcommand{\@epirule}{\color{dark}\rule[1ex]{\epigraphwidth}{\epigraphrule}}
\makeatother

